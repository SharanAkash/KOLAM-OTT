# QA Environment Configuration Example
NODE_ENV=qa

# Database - QA PostgreSQL Instance
DATABASE_URL="postgresql://username:password@host:5432/database?schema=public"

# AWS S3 Configuration - QA Bucket
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_REGION=us-east-1
AWS_S3_BUCKET=kolam-ott-qa-videos

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET_HERE
JWT_EXPIRES_IN=7d

# API Configuration
PORT=3001
API_URL=http://your-alb-url.elb.amazonaws.com

# CORS Origins - QA Web App
CORS_ORIGINS=http://your-alb-url.elb.amazonaws.com,http://localhost:3000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_PAYMENT=false
DEBUG_MODE=true
LOG_LEVEL=debug
