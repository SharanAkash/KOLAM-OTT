# Mumbai Environment Configuration
NODE_ENV=qa

# Database - Mumbai PostgreSQL Instance
DATABASE_URL="postgres://<user>:<pass>@<host>:5432/<db>?schema=public"

# AWS S3 Configuration - Mumbai Bucket
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
AWS_S3_BUCKET=kolam-ott-mumbai-videos

# File Upload Configuration (set USE_LOCAL_STORAGE=false to use S3)
USE_LOCAL_STORAGE=true
UPLOAD_DIR=/app/uploads
PUBLIC_URL=http://kolam-ott-mumbai-alb-XXXXX.ap-south-1.elb.amazonaws.com

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE
JWT_EXPIRES_IN=7d

# API Configuration
PORT=3001
API_URL=http://kolam-ott-mumbai-alb-XXXXX.ap-south-1.elb.amazonaws.com

# CORS Origins - Mumbai Web App
CORS_ORIGINS=http://kolam-ott-mumbai-alb-XXXXX.ap-south-1.elb.amazonaws.com,http://localhost:3000

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_PAYMENT=false
DEBUG_MODE=true
LOG_LEVEL=debug
